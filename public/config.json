{
  "system_dials": {
    "auto_accept_threshold": 85.0,
    "gatekeeper_warning_threshold": 45.0,
    "max_dropdown_candidates": 5
  },
  "algorithmic_weights": {
    "use_hybrid_engine": true,
    "levenshtein_weight": 0.4,
    "sorensen_dice_weight": 0.6
  },
  "token_typing_rules": {
    "numeric_strictness": 1.0,
    "alphabetic_strictness": 0.6,
    "alphanumeric_strictness": 0.9,
    "missing_numeric_penalty_multiplier": 2.5
  },
  "domain_modifiers": {
    "strip_hyphens_before_match": true,
    "ignore_leading_zeros_on_numbers": true
  },
  "noise_filters": {
    "global_stopwords": ["intl", "ms", "box", "handling", "quantity", "one", "of", "qty", "count"],
    "ignore_single_characters": true,
    "always_strip_characters": "[^a-zA-Z0-9 ]",
    "noise_patterns": [
      "so-[0-9]+",
      "box #[0-9]+ of [0-9]+"
    ]
  },
  "extraction_rules": {
    "use_line_anchor": true,
    "anchor_capture_pattern": "^([0-9]+x)-",
    "isolate_search_text": true
  },
  "output_formatting": {
    "include_extracted_quantity": true,
    "fallback_quantity_if_missing": "1x",
    "display_separator": " | ",
    "manifest_export_style": "{{QUANTITY}} {{PRODUCT}}"
  }
}